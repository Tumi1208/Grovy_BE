# Optional: change if you want the backend on a different port.
PORT=5050

# Paste your real MongoDB Atlas connection string after the = sign below.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/grovy?retryWrites=true&w=majority

# Future auth placeholders below are NOT active in the current MVP.
# Add real values only when authentication is implemented.
# JWT_ACCESS_SECRET=replace_when_auth_is_added
# JWT_REFRESH_SECRET=replace_when_auth_is_added
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
