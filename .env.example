# Optional: change if you want the backend on a different port.
PORT=5050

# Paste your real MongoDB Atlas connection string after the = sign below.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/grovy?retryWrites=true&w=majority

# Product data source:
# local = read src/data/products.json
# mongo = read MongoDB products only
# auto = use MongoDB when products exist there, otherwise fall back to local JSON
# Run `npm run products:check` before seeding.
# Run `npm run seed:products` to upsert src/data/products.json into MongoDB.
PRODUCT_DATA_SOURCE=local

# JWT settings for MVP auth. Replace the secret in non-demo environments.
JWT_ACCESS_SECRET=grovy-dev-access-secret
JWT_ACCESS_EXPIRES_IN=7d
